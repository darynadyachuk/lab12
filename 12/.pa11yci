  "defaults": {
    "timeout": 50000,
    "chromeLaunchConfig": {
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-dev-shm-usage",
        "--force-light-mode"
      ]
    }
  },
  "urls": [
    "http://127.0.0.1:5173/",
    "http://127.0.0.1:5173/people",
    "http://127.0.0.1:5173/todo"
  ]
}